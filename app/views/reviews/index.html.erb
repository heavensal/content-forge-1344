<% content_for :title, "Reviews — #{@website.name}" %>

<div class="mx-auto w-full max-w-5xl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div class="min-w-0">
      <%= link_to @website.name, @website, class: "text-xs font-medium uppercase tracking-wider text-emerald-500/90 hover:text-emerald-400" %>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-50 sm:text-3xl">Reviews</h1>
    </div>
    <%= link_to "New review", new_website_review_path(@website), class: primary_button_classes %>
  </div>

  <%= render "shared/public_api_fetch", endpoint: "reviews", resource_label: "Reviews" %>

  <% if @reviews.empty? %>
    <div class="<%= content_section_card_classes %> mt-10 text-center">
      <p class="text-zinc-400">No reviews yet.</p>
      <%= link_to "Create review", new_website_review_path(@website), class: "#{primary_button_classes} mt-4" %>
    </div>
  <% else %>
    <ul class="mt-10 divide-y divide-zinc-800 rounded-xl border border-zinc-800 bg-zinc-900/40">
      <% @reviews.each do |review| %>
        <li class="flex flex-col gap-3 px-4 py-4 sm:flex-row sm:items-center sm:justify-between sm:px-5">
          <div class="min-w-0 flex-1">
            <%= link_to (review.author.presence || "Draft review"), [@website, review], class: "break-words font-medium text-zinc-100 hover:text-emerald-400" %>
            <p class="mt-0.5 text-xs text-zinc-500">#<%= review.position %> · <%= review.status %></p>
          </div>
          <div class="flex w-full shrink-0 flex-col gap-2 sm:w-auto sm:flex-row sm:flex-wrap">
            <%= link_to "Edit", edit_website_review_path(@website, review), class: secondary_button_classes %>
            <%= button_to "Delete", [@website, review], method: :delete, form: { class: "block w-full sm:inline-block", data: { turbo_confirm: "Delete this review?" } }, class: danger_button_classes %>
          </div>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
