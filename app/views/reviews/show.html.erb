<% content_for :title, "Review — #{@website.name}" %>

<div class="mx-auto w-full max-w-3xl">
  <%= link_to "← Reviews", website_reviews_path(@website), class: "inline-flex min-h-11 items-center text-sm text-emerald-500/90 touch-manipulation hover:text-emerald-400" %>

  <header class="mt-6">
    <p class="text-xs font-medium uppercase tracking-wider text-zinc-500"><%= @review.status %> · #<%= @review.position %></p>
    <h1 class="mt-2 break-words text-xl font-semibold tracking-tight text-emerald-400 sm:text-2xl"><%= @review.author.presence || "—" %></h1>
    <% if @review.published_at.present? %>
      <p class="mt-2 text-sm text-zinc-500">Published <%= l @review.published_at, format: :long %></p>
    <% end %>
  </header>

  <div class="<%= content_section_card_classes %> mt-8">
    <div class="break-words text-sm leading-relaxed text-zinc-300 whitespace-pre-wrap"><%= @review.content.presence || "—" %></div>
  </div>

  <div class="mt-8 flex flex-col gap-2 sm:flex-row sm:flex-wrap">
    <%= link_to "Edit", edit_website_review_path(@website, @review), class: primary_button_classes %>
    <%= button_to "Delete", [@website, @review], method: :delete, form: { class: "block w-full sm:inline-block", data: { turbo_confirm: "Delete this review?" } }, class: danger_button_classes %>
  </div>
</div>
