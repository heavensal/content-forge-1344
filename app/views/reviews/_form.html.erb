<%= render "shared/model_errors", model: review %>

<%= form_with model: [@website, review], class: "space-y-6" do |f| %>
  <div>
    <%= f.label :author, class: label_classes %>
    <%= f.text_field :author, class: input_classes, autocomplete: "name" %>
    <p class="mt-1 text-xs text-zinc-500">Displayed name (required when published).</p>
  </div>

  <div>
    <%= f.label :content, class: label_classes %>
    <%= f.text_area :content, class: "#{input_classes} min-h-[140px]", rows: 6 %>
  </div>

  <div>
    <%= f.label :position, class: label_classes %>
    <%= f.number_field :position, class: input_classes, min: 0, step: 1 %>
  </div>

  <div>
    <%= f.label :status, class: label_classes %>
    <%= f.select :status, Review.statuses.keys.map { |k| [k.humanize, k] }, {}, class: input_classes %>
  </div>

  <div>
    <%= f.label :published_at, class: label_classes %>
    <%= f.datetime_field :published_at, class: input_classes %>
  </div>

  <div class="<%= form_footer_actions_classes %> pt-2">
    <%= f.submit class: primary_button_classes %>
    <%= link_to "Cancel", review.persisted? ? [@website, review] : website_reviews_path(@website), class: secondary_button_classes %>
  </div>
<% end %>
