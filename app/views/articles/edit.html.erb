  <h1 class="text-2xl font-semibold tracking-tight text-zinc-50">Edit article</h1>
  <p class="mt-1 text-sm text-zinc-500"><%= @article.title %></p>

  <div class="<%= content_section_card_classes %> mt-8">
    <%= render "form", article: @article %>
  </div>
</div>
