<% content_for :title, "#{@website.name} — ContentForge" %>

<div class="mx-auto w-full max-w-5xl">
  <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div class="min-w-0">
      <p class="text-xs font-medium uppercase tracking-wider text-emerald-500/90">Website</p>
      <h1 class="mt-1 text-2xl font-semibold tracking-tight text-zinc-50 sm:text-3xl"><%= @website.name %></h1>
      <p class="mt-1 break-all text-emerald-400/90 sm:break-normal"><%= @website.domain %></p>
      <p class="mt-2 inline-flex rounded-full bg-zinc-800 px-2.5 py-0.5 text-xs font-medium text-zinc-400 ring-1 ring-zinc-700"><%= @website.status %></p>
    </div>
    <div class="flex w-full flex-col gap-2 sm:w-auto sm:flex-row sm:flex-wrap">
      <%= link_to "Edit", edit_website_path(@website), class: secondary_button_classes %>
      <%= link_to "Articles", website_articles_path(@website), class: primary_button_classes %>
    </div>
  </div>

  <% if @website.description.present? %>
    <p class="mt-8 max-w-2xl text-sm leading-relaxed text-zinc-400"><%= @website.description %></p>
  <% end %>

  <div class="<%= content_section_card_classes %> mt-10">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">API access</h2>
    <p class="mt-2 text-sm text-zinc-500">Send this value as <code class="rounded bg-zinc-950 px-1.5 py-0.5 font-mono text-xs text-emerald-300/90">Authorization: Bearer &lt;token&gt;</code> from your external site.</p>
    <div class="mt-4 flex flex-col gap-2 sm:flex-row sm:items-center">
      <input type="text" readonly value="<%= @website.api_token %>" class="<%= input_classes %> min-w-0 font-mono text-xs sm:flex-1 sm:text-sm" id="website-api-token" onclick="this.select()" aria-label="API token" />
      <button type="button" class="<%= secondary_button_classes %> shrink-0" onclick="navigator.clipboard.writeText(document.getElementById('website-api-token').value)">
        Copy token
      </button>
    </div>
    <p class="mt-3 text-xs text-zinc-600">Keep this secret — anyone with the token can manage content for this website via the API.</p>
  </div>

  <div class="mt-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
    <%= link_to website_articles_path(@website), class: "#{content_section_card_classes} block transition hover:border-emerald-500/30 hover:ring-1 hover:ring-emerald-500/20" do %>
      <h3 class="font-semibold text-zinc-100">Articles</h3>
      <p class="mt-1 text-sm text-zinc-500">Blog posts for <%= @website.domain %></p>
      <p class="mt-4 text-2xl font-semibold text-emerald-400"><%= @website.articles.count %></p>
    <% end %>
    <%= link_to website_faqs_path(@website), class: "#{content_section_card_classes} block transition hover:border-emerald-500/30 hover:ring-1 hover:ring-emerald-500/20" do %>
      <h3 class="font-semibold text-zinc-100">FAQs</h3>
      <p class="mt-1 text-sm text-zinc-500">Questions &amp; answers</p>
      <p class="mt-4 text-2xl font-semibold text-emerald-400"><%= @website.faqs.count %></p>
    <% end %>
    <%= link_to website_reviews_path(@website), class: "#{content_section_card_classes} block transition hover:border-emerald-500/30 hover:ring-1 hover:ring-emerald-500/20" do %>
      <h3 class="font-semibold text-zinc-100">Reviews</h3>
      <p class="mt-1 text-sm text-zinc-500">Testimonials</p>
      <p class="mt-4 text-2xl font-semibold text-emerald-400"><%= @website.reviews.count %></p>
    <% end %>
  </div>
</div>
