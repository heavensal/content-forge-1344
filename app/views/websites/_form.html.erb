<%= render "shared/model_errors", model: website %>

<%= form_with model: website, class: "space-y-6" do |f| %>
  <div>
    <%= f.label :name, class: label_classes %>
    <%= f.text_field :name, class: input_classes, required: true, autocomplete: "organization" %>
  </div>

  <div>
    <%= f.label :domain, class: label_classes %>
    <%= f.text_field :domain, class: input_classes, required: true, placeholder: "example.com", autocomplete: "url" %>
    <p class="mt-1 text-xs text-zinc-500">Hostname only, no protocol. Used to identify this site for your external front end.</p>
  </div>

  <div>
    <%= f.label :description, class: label_classes %>
    <%= f.text_area :description, class: "#{input_classes} min-h-[100px]", rows: 4 %>
  </div>

  <div>
    <%= f.label :status, class: label_classes %>
    <%= f.select :status, Website.statuses.keys.map { |k| [k.humanize, k] }, {}, class: input_classes %>
  </div>

  <div class="<%= form_footer_actions_classes %> pt-2">
    <%= f.submit class: primary_button_classes %>
    <%= link_to "Cancel", website.persisted? ? website : websites_path, class: secondary_button_classes %>
  </div>
<% end %>
