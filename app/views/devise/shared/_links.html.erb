<div class="flex flex-col gap-2 text-center text-sm">
  <%- if controller_name != "sessions" %>
    <%= link_to "Sign in", new_session_path(resource_name), class: "text-emerald-500/90 hover:text-emerald-400" %>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != "registrations" %>
    <%= link_to "Create an account", new_registration_path(resource_name), class: "text-zinc-400 hover:text-zinc-200" %>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != "passwords" && controller_name != "registrations" %>
    <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-zinc-500 hover:text-zinc-300" %>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != "confirmations" %>
    <%= link_to "Resend confirmation", new_confirmation_path(resource_name), class: "text-zinc-500 hover:text-zinc-300" %>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != "unlocks" %>
    <%= link_to "Unlock instructions", new_unlock_path(resource_name), class: "text-zinc-500 hover:text-zinc-300" %>
  <% end %>

  <%- if devise_mapping.omniauthable? %>
    <%- resource_class.omniauth_providers.each do |provider| %>
      <%= button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: secondary_button_classes %>
    <% end %>
  <% end %>
</div>
