<% content_for :title, "Reset password — ContentForge" %>

<div class="<%= content_section_card_classes %>">
  <h1 class="text-xl font-semibold text-zinc-50">Set a new password</h1>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put, class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>
    <%= f.hidden_field :reset_password_token %>

    <div>
      <%= f.label :password, "New password", class: label_classes %>
      <% if @minimum_password_length %>
        <p class="text-xs text-zinc-500"><%= @minimum_password_length %> characters minimum</p>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: input_classes %>
    </div>

    <div>
      <%= f.label :password_confirmation, "Confirm new password", class: label_classes %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: input_classes %>
    </div>

    <div>
      <%= f.submit "Update password", class: primary_button_classes %>
    </div>
  <% end %>

  <div class="mt-8 border-t border-zinc-800 pt-6">
    <%= render "devise/shared/links" %>
  </div>
</div>
