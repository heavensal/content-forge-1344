<% content_for :title, "Forgot password — ContentForge" %>

<div class="<%= content_section_card_classes %>">
  <h1 class="text-xl font-semibold text-zinc-50">Forgot password?</h1>
  <p class="mt-1 text-sm text-zinc-500">We&apos;ll email you reset instructions.</p>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "mt-8 space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: label_classes %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: input_classes %>
    </div>

    <div>
      <%= f.submit "Send reset instructions", class: primary_button_classes %>
    </div>
  <% end %>

  <div class="mt-8 border-t border-zinc-800 pt-6">
    <%= render "devise/shared/links" %>
  </div>
</div>
