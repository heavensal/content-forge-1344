# PostgreSQL — used for development, test, and production (see config/database.yml).
# Copy to .env and set your real URL. Never commit .env.
#
# Neon: Project dashboard → Connection string → URI (use the pooler host for serverless).
# DATABASE_URL=postgresql://USER:PASSWORD@YOUR-POOLER.neon.tech/neondb?sslmode=require&channel_binding=require
#
# Local / CI (example):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/contentforge_1344_rails_development
#
# Kamal / Docker Hub (deploy) — Personal Access Token from hub.docker.com → Account Settings → Security
# KAMAL_REGISTRY_PASSWORD=dckr_pat_...

DATABASE_URL="database_url"
